    {
      "name": "History Weather API (/history.json)",
      "description": "Endpoint: GET /history.json\nRetorna datos históricos del tiempo para una fecha pasada.",
      "item": [
        {
          "name": "CP-API-011 [SMOKE] [HAPPY] Fecha histórica válida retorna datos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK con fecha histórica', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene estructura location + forecast', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('location');",
                  "    pm.expect(body).to.have.property('forecast');",
                  "    pm.expect(body.forecast.forecastday).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('La fecha retornada coincide con la solicitada', function () {",
                  "    const forecastDate = pm.response.json().forecast.forecastday[0].date;",
                  "    pm.expect(forecastDate).to.equal('2024-01-15');",
                  "});",
                  "",
                  "pm.test('Histórico incluye datos hora a hora (24 registros)', function () {",
                  "    const hours = pm.response.json().forecast.forecastday[0].hour;",
                  "    pm.expect(hours).to.be.an('array');",
                  "    pm.expect(hours.length).to.equal(24);",
                  "});",
                  "",
                  "pm.test('Cada hora tiene temperatura en Celsius y Fahrenheit', function () {",
                  "    const hours = pm.response.json().forecast.forecastday[0].hour;",
                  "    hours.slice(0, 3).forEach(function(h) {",
                  "        pm.expect(h).to.have.property('temp_c').that.is.a('number');",
                  "        pm.expect(h).to.have.property('temp_f').that.is.a('number');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
