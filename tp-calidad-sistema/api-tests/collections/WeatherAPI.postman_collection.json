    {
      "name": "Forecast Weather API (/forecast.json)",
      "description": "Endpoint: GET /forecast.json\nRetorna el pronóstico del tiempo para los próximos N días.",
      "item": [
        {
          "name": "CP-API-006 [SMOKE] [HAPPY] Pronóstico de 3 días retorna estructura correcta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta incluye objetos location, current y forecast', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys(['location', 'current', 'forecast']);",
                  "});",
                  "",
                  "pm.test('forecast.forecastday tiene exactamente 3 entradas', function () {",
                  "    const forecastDay = pm.response.json().forecast.forecastday;",
                  "    pm.expect(forecastDay).to.be.an('array');",
                  "    pm.expect(forecastDay.length).to.equal(3);",
                  "});",
                  "",
                  "pm.test('Cada día del pronóstico tiene fecha, day y hour', function () {",
                  "    const days = pm.response.json().forecast.forecastday;",
                  "    days.forEach(function(day) {",
                  "        pm.expect(day).to.have.property('date').that.is.a('string');",
                  "        pm.expect(day).to.have.property('day');",
                  "        pm.expect(day).to.have.property('hour').that.is.an('array');",
                  "        pm.expect(day.hour.length).to.equal(24);",
                  "    });",
                  "});",
                  "",
                  "pm.test('day contiene temp máxima, mínima y condición', function () {",
                  "    const day = pm.response.json().forecast.forecastday[0].day;",
                  "    pm.expect(day).to.have.property('maxtemp_c').that.is.a('number');",
                  "    pm.expect(day).to.have.property('mintemp_c').that.is.a('number');",
                  "    pm.expect(day).to.have.property('condition');",
                  "    pm.expect(day.condition).to.have.property('text');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/forecast.json?key={{api_key}}&q={{city_valid}}&days={{forecast_days}}&aqi=no&alerts=no",
              "host": ["{{base_url}}"],
              "path": ["forecast.json"],
              "query": [
                { "key": "key",    "value": "{{api_key}}" },
                { "key": "q",      "value": "{{city_valid}}" },
                { "key": "days",   "value": "{{forecast_days}}" },
                { "key": "aqi",    "value": "no" },
                { "key": "alerts", "value": "no" }
              ]
            }
          },
          "response": []
        },
