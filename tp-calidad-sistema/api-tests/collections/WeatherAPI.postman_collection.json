    {
      "name": "Realtime Weather API (/current.json)",
      "description": "Endpoint: GET /current.json\nRetorna el estado del tiempo en tiempo real para una ubicación.",
      "item": [
        {
          "name": "CP-API-001 [SMOKE] [HAPPY] Ciudad válida retorna datos de tiempo actual",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Tiempo de respuesta menor a 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene objeto location con campos requeridos', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('location');",
                  "    pm.expect(body.location).to.have.property('name').that.is.a('string');",
                  "    pm.expect(body.location).to.have.property('country').that.is.a('string');",
                  "    pm.expect(body.location).to.have.property('lat').that.is.a('number');",
                  "    pm.expect(body.location).to.have.property('lon').that.is.a('number');",
                  "    pm.expect(body.location).to.have.property('localtime').that.is.a('string');",
                  "});",
                  "",
                  "pm.test('Respuesta tiene objeto current con datos de temperatura', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('current');",
                  "    pm.expect(body.current).to.have.property('temp_c').that.is.a('number');",
                  "    pm.expect(body.current).to.have.property('temp_f').that.is.a('number');",
                  "    pm.expect(body.current).to.have.property('humidity').that.is.a('number');",
                  "    pm.expect(body.current).to.have.property('wind_kph').that.is.a('number');",
                  "    pm.expect(body.current).to.have.property('feelslike_c').that.is.a('number');",
                  "});",
                  "",
                  "pm.test('El objeto condition contiene texto descriptivo e ícono', function () {",
                  "    const current = pm.response.json().current;",
                  "    pm.expect(current).to.have.property('condition');",
                  "    pm.expect(current.condition).to.have.property('text').that.is.a('string');",
                  "    pm.expect(current.condition).to.have.property('icon').that.is.a('string');",
                  "    pm.expect(current.condition.text.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Content-Type es application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/current.json?key={{api_key}}&q={{city_valid}}&aqi=yes",
              "host": ["{{base_url}}"],
              "path": ["current.json"],
              "query": [
                { "key": "key", "value": "{{api_key}}" },
                { "key": "q",   "value": "{{city_valid}}" },
                { "key": "aqi", "value": "yes" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "CP-API-002 [HAPPY] Coordenadas GPS retornan datos correctos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK con coordenadas', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('La ubicación responde a las coordenadas enviadas', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.location).to.have.property('lat');",
                  "    pm.expect(body.location).to.have.property('lon');",
                  "    // Buenos Aires: lat ~-34.6, lon ~-58.3",
                  "    pm.expect(Math.abs(body.location.lat - (-34.6))).to.be.below(1);",
                  "});",
                  "",
                  "pm.test('current.last_updated es un string de fecha', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.current.last_updated).to.be.a('string');",
                  "    pm.expect(body.current.last_updated).to.match(/\\d{4}-\\d{2}-\\d{2}/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
